{
  "name": "graph-explorer",
  "private": true,
  "scripts": {
    "predev": "node scripts/free-dev-ports.mjs",
    "dev": "concurrently --kill-others-on-fail false -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "node scripts/run-dev-server.mjs",
    "dev:web": "npm run dev --prefix web",
    "build:web": "npm run build --prefix web",
    "install:all": "npm install && npm install --prefix web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
