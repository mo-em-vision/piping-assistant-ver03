# Backend API base URL (used in Phase 3+)
VITE_BACKEND_URL=http://localhost:8000

# Application display name
VITE_APP_NAME=Engineering Knowledge Graph Assistant

# Enable developer tooling and verbose diagnostics
VITE_DEV_MODE=true

# Use mock workspace data instead of backend API (development only)
VITE_MOCK_DATA=false

# OpenAI API key for backend AI explanations and chat (also readable from repo-root .env)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
